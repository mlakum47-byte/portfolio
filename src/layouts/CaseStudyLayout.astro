---
import BaseLayout from './BaseLayout.astro';
import Artwork from '../components/Artwork.astro';
import CaseStudyMeta from '../components/CaseStudyMeta.astro';
import CaseStudyToc from '../components/CaseStudyToc.astro';
import MetricList from '../components/MetricList.astro';
import NextProject from '../components/NextProject.astro';
import type { Project } from '../data/projects';
import '../styles/prose.css';

interface Props {
  project: Project;
  nextProject: Project;
}

const { project, nextProject } = Astro.props;
---

<BaseLayout title={`${project.title} — Mayank`} description={project.summary}>
  <article>
    <header class="case-hero container">
      <a class="back-link" href="/work">← All work</a>
      <p class="eyebrow">{project.eyebrow} · {project.year}</p>
      <h1>{project.title}</h1>
      <p class="case-hero__summary">{project.summary}</p>
      <Artwork palette={project.palette} label={`${project.title} abstract cover artwork`} large />
    </header>

    <div class="case-body container">
      <aside class="case-aside">
        <CaseStudyToc />
      </aside>
      <div class="case-content">
        <CaseStudyMeta project={project} />
        {project.confidentialityNote && <p class="confidentiality">{project.confidentialityNote}</p>}

        <div class="prose">
          <section id="challenge">
            <p class="eyebrow">01 — Context</p>
            <h2>The challenge</h2>
            <p>{project.challenge}</p>
          </section>

          <section id="contribution">
            <p class="eyebrow">02 — Role</p>
            <h2>My contribution</h2>
            <p>{project.contribution}</p>
          </section>

          <section id="insight">
            <p class="eyebrow">03 — Research</p>
            <h2>What we learned</h2>
            <p>{project.insight}</p>
            <blockquote>Designing for confidence means making the next meaningful action easy to find—and easy to trust.</blockquote>
          </section>

          <section id="direction">
            <p class="eyebrow">04 — Making</p>
            <h2>Design direction</h2>
            <p>{project.direction}</p>
            <figure class="process-figure">
              <div class:list={['process-visual', `process-visual--${project.palette}`]} aria-label="Illustrative interface exploration" role="img">
                <span></span><span></span><span></span><i></i>
              </div>
              <figcaption>An illustrative placeholder for the flow, artefacts, and decision rationale that will accompany the final case study.</figcaption>
            </figure>
          </section>

          <section id="validation">
            <p class="eyebrow">05 — Learning</p>
            <h2>Validation and iteration</h2>
            <p>{project.validation}</p>
          </section>

          <section id="outcome">
            <p class="eyebrow">06 — Impact</p>
            <h2>Outcome</h2>
            <p>{project.outcome}</p>
          </section>
        </div>

        <MetricList outcomes={project.outcomes} />

        <div class="prose">
          <section id="reflection">
            <p class="eyebrow">07 — Looking back</p>
            <h2>Reflection</h2>
            <p>{project.reflection}</p>
          </section>
        </div>

        <NextProject project={nextProject} />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .case-hero {
    padding-top: clamp(2rem, 6vw, 5rem);
  }

  .back-link {
    display: inline-block;
    margin-bottom: clamp(3.5rem, 8vw, 7rem);
    color: var(--ink-soft);
    font-size: 0.76rem;
    font-weight: 700;
    text-decoration: none;
  }

  .case-hero .eyebrow {
    margin-bottom: 1.1rem;
  }

  h1 {
    max-width: 10ch;
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(3.8rem, 9vw, 8.7rem);
    font-weight: 400;
    letter-spacing: -0.065em;
    line-height: 0.88;
  }

  .case-hero__summary {
    max-width: 40rem;
    margin: 1.5rem 0 clamp(2.5rem, 5vw, 4rem);
    color: var(--ink-soft);
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    line-height: 1.45;
  }

  .case-body {
    display: grid;
    grid-template-columns: minmax(10rem, 14rem) minmax(0, var(--reading-width));
    justify-content: center;
    gap: clamp(2rem, 7vw, 8rem);
    padding-top: var(--space-6);
  }

  .case-content > .meta-list {
    margin-bottom: 1.25rem;
  }

  .confidentiality {
    margin: 0;
    padding: 0.85rem 1rem;
    color: #4a4d43;
    background: #ebe8df;
    border-radius: 0.5rem;
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .process-figure {
    margin: 2.5rem 0;
  }

  .process-visual {
    position: relative;
    display: grid;
    grid-template-columns: 0.8fr 1.4fr;
    grid-template-rows: repeat(2, 1fr);
    min-height: 18rem;
    gap: 0.8rem;
    padding: 1rem;
    overflow: hidden;
    border-radius: 1rem;
  }

  .process-visual--coral { background: #e9a48d; }
  .process-visual--blue { background: #a4cbd2; }
  .process-visual--green { background: #b9c9a8; }

  .process-visual span,
  .process-visual i {
    position: relative;
    z-index: 1;
    display: block;
    background: #fdfcf8;
    border-radius: 0.5rem;
  }

  .process-visual span:first-child { grid-row: 1 / -1; }
  .process-visual span:nth-child(3) { width: 70%; }
  .process-visual i {
    position: absolute;
    right: -5%;
    bottom: -25%;
    width: 48%;
    aspect-ratio: 1;
    background: rgb(23 33 29 / 85%);
    border-radius: 50%;
  }

  figcaption {
    margin-top: 0.75rem;
    color: var(--ink-soft);
    font-size: 0.74rem;
    line-height: 1.45;
  }

  @media (max-width: 58rem) {
    .case-body {
      grid-template-columns: 1fr;
    }
  }
</style>
