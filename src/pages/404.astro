---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Mayank">
  <section class="not-found container">
    <p class="eyebrow">404 — Wrong turn</p>
    <h1>This page has<br />wandered <em>off path.</em></h1>
    <p>Let’s get you back to the work.</p>
    <a href="/work">Explore case studies <span aria-hidden="true">↗</span></a>
  </section>
</BaseLayout>

<style>
  .not-found { min-height: 60vh; padding-top: clamp(5rem, 14vw, 12rem); }
  h1 { margin: 1rem 0 1.5rem; font-family: var(--serif); font-size: clamp(3.7rem, 10vw, 9rem); font-weight: 400; letter-spacing: -0.07em; line-height: 0.85; }
  em { color: var(--accent); }
  p:not(.eyebrow) { color: var(--ink-soft); }
  a { display: inline-block; margin-top: 1rem; font-weight: 700; text-decoration: none; }
</style>
