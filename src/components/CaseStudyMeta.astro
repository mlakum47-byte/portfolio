---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const details = [
  ['Role', project.role],
  ['Team', project.team],
  ['Timeline', project.duration],
  ['Platform', project.platform],
];
---

<dl class="meta-list">
  {details.map(([term, description]) => (
    <div>
      <dt>{term}</dt>
      <dd>{description}</dd>
    </div>
  ))}
</dl>

<style>
  .meta-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem 2rem;
    margin: 0;
  }

  .meta-list div {
    padding-top: 0.75rem;
    border-top: 1px solid var(--line);
  }

  dt {
    color: var(--ink-soft);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  dd {
    margin: 0.35rem 0 0;
    font-size: 0.84rem;
    line-height: 1.45;
  }

  @media (max-width: 35rem) {
    .meta-list {
      grid-template-columns: 1fr;
    }
  }
</style>
