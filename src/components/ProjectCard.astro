---
import Artwork from './Artwork.astro';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
---

<article class:list={['project-card', { 'project-card--featured': featured }]}>
  <a href={`/work/${project.slug}`} class="project-card__link">
    <Artwork palette={project.palette} label={`${project.title} project artwork`} />
    <div class="project-card__details">
      <p class="eyebrow">{project.category} · {project.year}</p>
      <p class="project-card__title">{project.title}</p>
      <p>{project.summary}</p>
      <span class="project-card__cta">Read case study <span aria-hidden="true">↗</span></span>
    </div>
  </a>
</article>

<style>
  .project-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .project-card__link:hover :global(.artwork) {
    transform: translateY(-0.3rem);
    box-shadow: var(--shadow);
  }

  :global(.artwork) {
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .project-card__details {
    padding: 1.1rem 0.15rem 0;
  }

  .project-card__title {
    max-width: 16ch;
    margin: 0.45rem 0 0.7rem;
    color: var(--ink);
    font-family: var(--serif);
    font-size: clamp(1.85rem, 3.5vw, 2.8rem);
    font-weight: 400;
    letter-spacing: -0.05em;
    line-height: 0.95;
  }

  .project-card__details > p:not(.eyebrow) {
    max-width: 39ch;
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.91rem;
  }

  .project-card__cta {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.78rem;
    font-weight: 700;
  }
</style>
