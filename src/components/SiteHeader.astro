---
const { currentPath = '/' } = Astro.props;
const navItems = [
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="wordmark" href="/" aria-label="Mayank — home">
      <span>Mayank</span>
      <span>UI/UX Designer</span>
    </a>

    <nav aria-label="Primary navigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
        <li><a href="mailto:hello@mayank.design">Let’s talk <span aria-hidden="true">↗</span></a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--line);
  }

  .header-inner,
  nav ul {
    display: flex;
    align-items: center;
  }

  .header-inner {
    justify-content: space-between;
    gap: 1rem;
  }

  .wordmark {
    display: grid;
    gap: 0.02rem;
    color: var(--ink);
    font-family: var(--serif);
    font-size: 1.15rem;
    line-height: 1;
    text-decoration: none;
  }

  .wordmark span:last-child {
    color: var(--ink-soft);
    font-family: var(--sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  nav ul {
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: clamp(0.75rem, 2.5vw, 2rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav a {
    color: var(--ink-soft);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }

  nav a[aria-current='page'],
  nav a:hover {
    color: var(--ink);
  }

  nav li:last-child a {
    color: var(--ink);
  }

  @media (max-width: 35rem) {
    .header-inner {
      align-items: flex-start;
    }

    nav ul {
      gap: 0.6rem 1rem;
    }

    nav a {
      font-size: 0.72rem;
    }
  }
</style>
