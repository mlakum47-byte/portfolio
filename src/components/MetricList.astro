---
interface Props {
  outcomes: string[];
}

const { outcomes } = Astro.props;
---

<ul class="metric-list" aria-label="Project outcomes">
  {outcomes.map((outcome) => (
    <li><span aria-hidden="true">✦</span>{outcome}</li>
  ))}
</ul>

<style>
  .metric-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 2.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .metric-list li {
    min-height: 7rem;
    padding: 1rem;
    color: var(--ink);
    background: #ebe8df;
    border-radius: 0.75rem;
    font-family: var(--serif);
    font-size: 1.15rem;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .metric-list span {
    display: block;
    margin-bottom: 1.5rem;
    color: var(--accent);
    font-family: var(--sans);
    font-size: 0.8rem;
  }

  @media (max-width: 38rem) {
    .metric-list {
      grid-template-columns: 1fr;
    }

    .metric-list li {
      min-height: 0;
    }
  }
</style>
